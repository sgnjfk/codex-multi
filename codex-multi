#!/usr/bin/env bash
# codex-multi — wrapper for managing multiple Codex CLI accounts
# Usage:
#   codex-multi add <name>        — login and save a new account
#   codex-multi rm <name>         — remove an account
#   codex-multi ls                — list all accounts
#   codex-multi use <name>        — set default account
#   codex-multi balance           — switch to account with most quota
#   codex-multi backup <file>     — archive all accounts/config for transfer
#   codex-multi restore <file>    — restore all accounts/config from archive
#   codex-multi set lb <addr>     — save codex-lb URL in ~/.codex-multi
#   codex-multi get lb            — show saved codex-lb URL
#   codex-multi set api-key <key> — save codex-lb API key
#   codex-multi get api-key       — show saved codex-lb API key
#   codex-multi migrate            — merge history from all accounts into shared ~/.codex
#   codex-multi status [name]     — check login status
#   codex-multi <name> [args...]  — run codex with specific account
#   codex-multi [args...]         — run codex with default account

set -euo pipefail

MULTI_HOME="${CODEX_MULTI_HOME:-$HOME/.codex-multi}"
ACCOUNTS_DIR="$MULTI_HOME/accounts"
DEFAULT_FILE="$MULTI_HOME/default"
CONFIG_FILE="$MULTI_HOME/config"

mkdir -p "$ACCOUNTS_DIR"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
dim()   { printf '\033[90m%s\033[0m\n' "$*"; }

get_default() {
  [ -f "$DEFAULT_FILE" ] && cat "$DEFAULT_FILE" || echo ""
}

get_config() {
  local key="$1"
  [ -f "$CONFIG_FILE" ] && grep -m1 "^${key}=" "$CONFIG_FILE" 2>/dev/null | cut -d= -f2- || echo ""
}

set_config() {
  local key="$1" value="$2"
  if [ -f "$CONFIG_FILE" ] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$CONFIG_FILE"
  else
    echo "${key}=${value}" >> "$CONFIG_FILE"
  fi
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

get_lb_api_key() {
  get_config lb_api_key
}

# curl wrapper that injects "Authorization: Bearer <key>" when api-key is configured.
lb_curl() {
  local key
  key=$(get_lb_api_key)
  if [ -n "$key" ]; then
    curl -H "Authorization: Bearer $key" "$@"
  else
    curl "$@"
  fi
}

normalize_lb_url() {
  local raw="$1"
  python3 -c "
import sys
from urllib.parse import urlparse

raw = sys.argv[1].strip()
if not raw:
    raise SystemExit(1)

candidate = raw if '://' in raw else f'http://{raw}'
parsed = urlparse(candidate)

if parsed.scheme not in ('http', 'https'):
    raise SystemExit(1)
if not parsed.netloc:
    raise SystemExit(1)
if parsed.params or parsed.query or parsed.fragment:
    raise SystemExit(1)

path = parsed.path.rstrip('/')
if path and path != '/':
    raise SystemExit(1)

print(f'{parsed.scheme}://{parsed.netloc}')
" "$raw" 2>/dev/null
}

get_email() {
  local dir="$1"
  [ -f "$dir/auth.json" ] || return
  python3 -c "
import json, base64, sys
try:
  d = json.load(open('$dir/auth.json'))
  token = d.get('tokens',{}).get('id_token','')
  if token:
    payload = token.split('.')[1]
    payload += '=' * (4 - len(payload) % 4)
    info = json.loads(base64.b64decode(payload))
    print(info.get('email',''))
except: pass
" 2>/dev/null
}

cmd_add() {
  local name="$1"
  local dir="$ACCOUNTS_DIR/$name"
  echo "Logging in as '$name'..."
  cmd_add_internal "$name"
  [ ! -f "$DEFAULT_FILE" ] && echo "$name" > "$DEFAULT_FILE" && dim "Set as default"
}

cmd_add_remote() {
  local name="$1"
  local dir="$ACCOUNTS_DIR/$name"

  # Start codex login in background — it listens on 127.0.0.1:1455
  # Use CODEX_HOME directly for login (writes auth.json to account dir)
  CODEX_HOME="$dir" codex login &
  local login_pid=$!
  sleep 2

  # Extract OAuth URL from codex output (if available), otherwise guide user
  echo ""
  dim "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  dim "Remote login mode"
  dim "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  dim "1. Open the OAuth URL above in your browser"
  dim "2. Login with your ChatGPT account"
  dim "3. Browser will redirect to http://127.0.0.1:1455/... (will fail)"
  dim "4. Copy the FULL URL from the browser address bar"
  dim "5. Paste it below:"
  echo ""
  printf '\033[1;36m> Callback URL: \033[0m'
  read -r callback_url

  if [ -z "$callback_url" ]; then
    red "No URL provided"
    kill "$login_pid" 2>/dev/null; wait "$login_pid" 2>/dev/null
    exit 1
  fi

  # Forward the callback to codex login running on localhost
  local path="${callback_url#*127.0.0.1:1455}"
  path="${path#*localhost:1455}"
  if [ -z "$path" ] || [ "$path" = "$callback_url" ]; then
    # User pasted full URL, try as-is replacing host
    path="${callback_url#http://127.0.0.1:1455}"
    path="${path#http://localhost:1455}"
  fi

  dim "Forwarding callback..."
  curl -s --max-time 10 "http://127.0.0.1:1455${path}" > /dev/null 2>&1 || true

  # Wait up to 15s for auth.json to appear
  local waited=0
  while [ $waited -lt 15 ]; do
    [ -f "$dir/auth.json" ] && break
    sleep 1
    waited=$((waited + 1))
  done

  # Cleanup background process
  kill "$login_pid" 2>/dev/null; wait "$login_pid" 2>/dev/null || true

  if [ -f "$dir/auth.json" ]; then
    local email=$(get_email "$dir")
    [ -n "$email" ] && green "Added: $name ($email)" || green "Added: $name"
    [ ! -f "$DEFAULT_FILE" ] && echo "$name" > "$DEFAULT_FILE" && dim "Set as default"
  else
    red "Login failed — auth.json not created"
    dim "Try: codex-multi import $name /path/to/auth.json"
  fi
}

cmd_import() {
  local name="$1"
  local src="$2"
  local dir="$ACCOUNTS_DIR/$name"
  mkdir -p "$dir"

  if [ "$src" = "-" ]; then
    dim "Paste auth.json content, then Ctrl+D:"
    cat > "$dir/auth.json"
  elif [ -f "$src" ]; then
    cp "$src" "$dir/auth.json"
  else
    red "File not found: $src" && exit 1
  fi

  chmod 600 "$dir/auth.json"
  local email=$(get_email "$dir")
  [ -n "$email" ] && green "Imported: $name ($email)" || green "Imported: $name"
  [ ! -f "$DEFAULT_FILE" ] && echo "$name" > "$DEFAULT_FILE" && dim "Set as default"
}

cmd_export() {
  local name="$1"
  local dir="$ACCOUNTS_DIR/$name"
  [ ! -f "$dir/auth.json" ] && red "No auth.json for '$name'" && exit 1
  cat "$dir/auth.json"
}

cmd_set() {
  local key="$1"
  local value="${2:-}"

  case "$key" in
    lb)
      [ -z "$value" ] && red "Usage: codex-multi set lb <ip:port | http://host:port | https://host:port>" && exit 1
      local normalized
      normalized=$(normalize_lb_url "$value") || {
        red "Invalid codex-lb address: $value"
        dim "Expected: ip:port, host:port, http://host:port, or https://host:port"
        exit 1
      }
      set_config "lb_url" "$normalized"
      green "codex-lb URL saved: $normalized"
      ;;
    api-key|api_key)
      [ -z "$value" ] && red "Usage: codex-multi set api-key <key>" && exit 1
      set_config "lb_api_key" "$value"
      green "codex-lb API key saved"
      ;;
    *)
      red "Unknown setting: $key"
      dim "Supported: lb, api-key"
      exit 1
      ;;
  esac
}

cmd_get() {
  local key="$1"

  case "$key" in
    lb)
      local url
      url=$(get_config lb_url)
      [ -z "$url" ] && red "codex-lb URL not set" && dim "Run: codex-multi set lb <ip:port>" && exit 1
      printf '%s\n' "$url"
      ;;
    api-key|api_key)
      local k
      k=$(get_lb_api_key)
      [ -z "$k" ] && red "codex-lb API key not set" && dim "Run: codex-multi set api-key <key>" && exit 1
      printf '%s\n' "$k"
      ;;
    *)
      red "Unknown setting: $key"
      dim "Supported: lb, api-key"
      exit 1
      ;;
  esac
}

cmd_backup() {
  local dest="$1"
  mkdir -p "$MULTI_HOME"

  if [ ! -d "$ACCOUNTS_DIR" ] || [ -z "$(find "$ACCOUNTS_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)" ]; then
    red "No accounts to back up" && exit 1
  fi

  mkdir -p "$(dirname "$dest")"
  tar -czf "$dest" -C "$MULTI_HOME" .
  chmod 600 "$dest" 2>/dev/null || true
  green "Backup created: $dest"
}

cmd_restore() {
  local src="$1"
  [ ! -f "$src" ] && red "File not found: $src" && exit 1

  mkdir -p "$MULTI_HOME"
  tar -xzf "$src" -C "$MULTI_HOME"

  chmod 700 "$MULTI_HOME" "$ACCOUNTS_DIR" 2>/dev/null || true
  find "$ACCOUNTS_DIR" -type d -exec chmod 700 {} \; 2>/dev/null || true
  find "$ACCOUNTS_DIR" -type f -name auth.json -exec chmod 600 {} \; 2>/dev/null || true
  find "$ACCOUNTS_DIR" -type f -name config.toml -exec chmod 600 {} \; 2>/dev/null || true
  [ -f "$DEFAULT_FILE" ] && chmod 600 "$DEFAULT_FILE" 2>/dev/null || true

  local default=""
  default=$(get_default)
  if [ -n "$default" ] && [ -d "$ACCOUNTS_DIR/$default" ]; then
    cmd_use "$default" >/dev/null
    green "Restored: $src"
    dim "Default account restored: $default"
  else
    green "Restored: $src"
    dim "Run: codex-multi use <name> to recreate ~/.codex symlink"
  fi
}

cmd_rm() {
  local name="$1"
  local dir="$ACCOUNTS_DIR/$name"
  [ ! -d "$dir" ] && red "Account '$name' not found" && exit 1
  rm -rf "$dir"
  [ "$(get_default)" = "$name" ] && rm -f "$DEFAULT_FILE"
  green "Removed: $name"
}

cmd_ls() {
  local default=$(get_default)
  local found=0
  for dir in "$ACCOUNTS_DIR"/*/; do
    [ ! -d "$dir" ] && continue
    found=1
    local name=$(basename "$dir")
    local email=$(get_email "$dir")
    local marker="  "
    [ "$name" = "$default" ] && marker="* "
    if [ -n "$email" ]; then
      printf '%s%s (%s)\n' "$marker" "$name" "$email"
    else
      printf '%s%s\n' "$marker" "$name"
    fi
  done
  [ $found -eq 0 ] && dim "No accounts. Run: codex-multi add <name>"
}

cmd_use() {
  local name="$1"
  [ ! -d "$ACCOUNTS_DIR/$name" ] && red "Account '$name' not found" && exit 1
  echo "$name" > "$DEFAULT_FILE"

  local codex_home="$HOME/.codex"
  local acct_dir="$ACCOUNTS_DIR/$name"

  # Must migrate first if ~/.codex is still a symlink (old layout)
  if [ -L "$codex_home" ]; then
    red "~/.codex is a symlink (old layout). Run 'codex-multi migrate' first."
    exit 1
  fi

  # Ensure ~/.codex is a real directory
  if [ ! -d "$codex_home" ]; then
    mkdir -p "$codex_home"
  fi

  # Symlink only auth.json into ~/.codex (config.toml is shared, not per-account)
  rm -f "$codex_home/auth.json"
  ln -s "$acct_dir/auth.json" "$codex_home/auth.json"

  green "Default: $name (codex + codex-multi)"
}

# Shared files/dirs that should live in ~/.codex (merged during migration)
SHARED_ITEMS="config.toml history.jsonl sessions memories shell_snapshots state_5.sqlite logs_1.sqlite cache log tmp skills models_cache.json version.json"

cmd_migrate_undo() {
  local backup_file
  backup_file=$(ls -t "$MULTI_HOME"/pre-migrate-*.tar.gz 2>/dev/null | head -1)
  [ -z "$backup_file" ] && red "No migration backup found in $MULTI_HOME" && exit 1

  dim "Restoring from: $backup_file"

  # Remove current state
  rm -rf "$HOME/.codex" "$HOME/.codex.merged"

  # Restore from backup
  tar -xzf "$backup_file" -C "$HOME"

  chmod 700 "$MULTI_HOME" "$ACCOUNTS_DIR" 2>/dev/null || true
  find "$ACCOUNTS_DIR" -type f -name auth.json -exec chmod 600 {} \; 2>/dev/null || true

  green "Restored to pre-migration state"
  dim "Backup kept: $backup_file"
}

cmd_migrate() {
  local codex_home="$HOME/.codex"
  local merged_dir="$codex_home.merged"

  local existing_backup
  existing_backup=$(ls -t "$MULTI_HOME"/pre-migrate-*.tar.gz 2>/dev/null | head -1 || true)
  if [ -n "$existing_backup" ]; then
    echo ""
    dim "Found existing backup: $existing_backup"
    dim "This could be from a previous failed migration or a successful one."
    echo ""
    printf '  [u] Undo — restore from backup, then migrate again\n'
    printf '  [d] Delete backup and migrate current state\n'
    printf '  [q] Quit\n'
    echo ""
    printf '> '
    read -r choice
    case "$choice" in
      u|U)
        cmd_migrate_undo
        ;;
      d|D)
        rm -f "$MULTI_HOME"/pre-migrate-*.tar.gz
        dim "Backup removed"
        ;;
      *)
        exit 0
        ;;
    esac
  fi

  # Backup current state (create in /tmp first, then move in)
  local backup_name="pre-migrate-$(date +%Y%m%d-%H%M%S).tar.gz"
  local backup_tmp="/tmp/$backup_name"
  local backup_file="$MULTI_HOME/$backup_name"
  dim "Backing up → $backup_file"
  tar -czf "$backup_tmp" -C "$HOME" .codex-multi/ .codex || { red "Backup failed — aborting migration"; rm -f "$backup_tmp"; exit 1; }
  mv "$backup_tmp" "$backup_file"
  chmod 600 "$backup_file"
  green "Backup saved: $backup_file"

  dim "Migrating to shared-history layout..."

  # Create merged dir
  mkdir -p "$merged_dir"

  # Merge data from all account dirs
  local history_tmp=$(mktemp)
  for acct_dir in "$ACCOUNTS_DIR"/*/; do
    [ ! -d "$acct_dir" ] && continue
    local acct_name=$(basename "$acct_dir")

    # Merge history.jsonl (append, deduplicate later)
    if [ -f "$acct_dir/history.jsonl" ]; then
      cat "$acct_dir/history.jsonl" >> "$history_tmp"
    fi

    # Merge sessions (copy without overwriting)
    if [ -d "$acct_dir/sessions" ]; then
      cp -rn "$acct_dir/sessions/." "$merged_dir/sessions/" 2>/dev/null || true
    fi

    # Merge memories
    if [ -d "$acct_dir/memories" ]; then
      cp -rn "$acct_dir/memories/." "$merged_dir/memories/" 2>/dev/null || true
    fi

    # Merge shell_snapshots
    if [ -d "$acct_dir/shell_snapshots" ]; then
      cp -rn "$acct_dir/shell_snapshots/." "$merged_dir/shell_snapshots/" 2>/dev/null || true
    fi

    # Pick the most complete config.toml (most lines = most settings)
    if [ -f "$acct_dir/config.toml" ]; then
      if [ ! -f "$merged_dir/config.toml" ] || \
         [ "$(wc -l < "$acct_dir/config.toml")" -gt "$(wc -l < "$merged_dir/config.toml")" ]; then
        cp "$acct_dir/config.toml" "$merged_dir/config.toml"
      fi
    fi

    # Copy other shared files (keep latest by mtime)
    for f in models_cache.json version.json; do
      if [ -f "$acct_dir/$f" ]; then
        if [ ! -f "$merged_dir/$f" ] || [ "$acct_dir/$f" -nt "$merged_dir/$f" ]; then
          cp "$acct_dir/$f" "$merged_dir/$f"
        fi
      fi
    done

    # Copy dirs (keep latest content, don't overwrite)
    for d in cache log tmp skills; do
      if [ -d "$acct_dir/$d" ]; then
        mkdir -p "$merged_dir/$d"
        cp -rn "$acct_dir/$d/." "$merged_dir/$d/" 2>/dev/null || true
      fi
    done
  done

  # Deduplicate and sort history by timestamp
  if [ -s "$history_tmp" ]; then
    python3 -c "
import json, sys

seen = set()
entries = []
for line in open('$history_tmp'):
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
        key = (obj.get('session_id',''), obj.get('ts',0), obj.get('text',''))
        if key not in seen:
            seen.add(key)
            entries.append((obj.get('ts',0), line))
    except:
        entries.append((0, line))

entries.sort(key=lambda x: x[0])
with open('$merged_dir/history.jsonl', 'w') as f:
    for _, line in entries:
        f.write(line + '\n')
" 2>/dev/null
  fi
  rm -f "$history_tmp"

  # Merge sqlite databases
  cmd_migrate_sqlite "$merged_dir"

  # Verify merged results before committing
  local src_history=0 merged_history=0 src_threads=0 merged_threads=0
  for acct_dir in "$ACCOUNTS_DIR"/*/; do
    if [ -f "$acct_dir/history.jsonl" ]; then
      src_history=$((src_history + $(wc -l < "$acct_dir/history.jsonl")))
    fi
    if [ -f "$acct_dir/state_5.sqlite" ]; then
      src_threads=$((src_threads + $(python3 -c "
import sqlite3; print(sqlite3.connect('$acct_dir/state_5.sqlite').execute('SELECT count(*) FROM threads').fetchone()[0])
" 2>/dev/null || echo 0)))
    fi
  done
  if [ -f "$merged_dir/history.jsonl" ]; then
    merged_history=$(wc -l < "$merged_dir/history.jsonl")
  fi
  if [ -f "$merged_dir/state_5.sqlite" ]; then
    merged_threads=$(python3 -c "
import sqlite3; print(sqlite3.connect('$merged_dir/state_5.sqlite').execute('SELECT count(*) FROM threads').fetchone()[0])
" 2>/dev/null || echo 0)
  fi

  dim "Verify: history $merged_history/$src_history lines, threads $merged_threads/$src_threads"

  # merged_history can be <= src_history due to dedup, but should not be 0 if source had data
  if [ "$src_history" -gt 0 ] && [ "$merged_history" -eq 0 ]; then
    red "Verification failed: history lost after merge. Run 'cm migrate --undo' to restore."
    exit 1
  fi
  if [ "$src_threads" -gt 0 ] && [ "$merged_threads" -eq 0 ]; then
    red "Verification failed: threads lost after merge. Run 'cm migrate --undo' to restore."
    exit 1
  fi

  # Replace ~/.codex with merged dir
  if [ -L "$codex_home" ]; then
    rm "$codex_home"
  elif [ -d "$codex_home" ]; then
    mv "$codex_home" "$codex_home.bak.$(date +%s)"
  fi
  mv "$merged_dir" "$codex_home"

  # Clean shared files from account dirs (keep only auth files)
  for acct_dir in "$ACCOUNTS_DIR"/*/; do
    [ ! -d "$acct_dir" ] && continue
    for item in $SHARED_ITEMS; do
      if [ -e "$acct_dir/$item" ]; then
        rm -rf "$acct_dir/$item"
      fi
    done
    # Clean sqlite WAL/SHM files
    rm -f "$acct_dir"/*.sqlite-wal "$acct_dir"/*.sqlite-shm
    # Clean misc files
    rm -f "$acct_dir/.personality_migration"
  done

  green "Migration complete — history/sessions merged into ~/.codex"
  dim "Backup kept: $(ls -t "$MULTI_HOME"/pre-migrate-*.tar.gz 2>/dev/null | head -1)"
  dim "Run 'cm migrate --undo' to revert, or 'cm migrate --clean' to remove backup"
}

cmd_migrate_sqlite() {
  local dest_dir="$1"
  python3 -c "
import sqlite3, os, glob, shutil, sys

accounts_dir = '$ACCOUNTS_DIR'

for db_name in ['state_5.sqlite', 'logs_1.sqlite']:
    db_files = sorted(glob.glob(os.path.join(accounts_dir, '*', db_name)))
    if not db_files:
        continue

    dest_db = os.path.join('$dest_dir', db_name)
    db_files.sort(key=lambda f: os.path.getsize(f), reverse=True)

    # Find first valid db as base
    base = None
    for f in db_files:
        try:
            conn = sqlite3.connect(f)
            conn.execute('SELECT count(*) FROM sqlite_master')
            conn.close()
            base = f
            break
        except Exception:
            print(f'  skip corrupt: {f}', file=sys.stderr)

    if not base:
        continue

    shutil.copy2(base, dest_db)
    dest_conn = sqlite3.connect(dest_db)
    dest_conn.execute('PRAGMA journal_mode=WAL')

    for src_file in db_files:
        if src_file == base:
            continue
        try:
            src_conn = sqlite3.connect(src_file)
            tables = [r[0] for r in src_conn.execute(
                \"SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE '_sqlx%'\"
            ).fetchall()]

            for table in tables:
                try:
                    cols = [r[1] for r in src_conn.execute(f'PRAGMA table_info({table})').fetchall()]
                    rows = src_conn.execute(f'SELECT * FROM {table}').fetchall()
                    if rows:
                        placeholders = ','.join(['?'] * len(cols))
                        dest_conn.executemany(
                            f'INSERT OR IGNORE INTO {table} VALUES ({placeholders})',
                            rows
                        )
                except Exception:
                    pass

            src_conn.close()
        except Exception:
            pass

    dest_conn.commit()
    dest_conn.close()
"
}

cmd_status() {
  local name="${1:-$(get_default)}"
  [ -z "$name" ] && red "No account specified and no default set" && exit 1
  [ ! -d "$ACCOUNTS_DIR/$name" ] && red "Account '$name' not found" && exit 1
  local prev_default=$(get_default)
  cmd_use "$name" > /dev/null
  local exit_code=0
  codex login status || exit_code=$?
  [ -n "$prev_default" ] && [ "$prev_default" != "$name" ] && cmd_use "$prev_default" > /dev/null
  return $exit_code
}

cmd_reauth() {
  local name="$1"
  local sync_lb="$2"
  local dir="$ACCOUNTS_DIR/$name"
  [ ! -d "$dir" ] && red "Account '$name' not found" && exit 1

  local email=$(get_email "$dir")
  dim "Re-authenticating: $name${email:+ ($email)}"

  [ -f "$dir/auth.json" ] && cp "$dir/auth.json" "$dir/auth.json.bak"

  rm -f "$dir/auth.json"
  cmd_add_internal "$name"

  if [ "$sync_lb" = "1" ] && [ -f "$dir/auth.json" ]; then
    local lb_url=$(get_config lb_url)
    if [ -z "$lb_url" ]; then
      red "lb_url not configured. Run: cm set lb <ip:port>"
      return 1
    fi
    dim "Importing to codex-lb..."
    local lb_resp
    lb_resp=$(lb_curl -s --max-time 10 -w "\n%{http_code}" -X POST \
      "$lb_url/api/accounts/import" \
      -F "auth_json=@$dir/auth.json" 2>&1)
    local http_code=$(echo "$lb_resp" | tail -1)
    case "$http_code" in
      200|201)
        green "Re-imported to codex-lb"
        ;;
      401|403)
        red "codex-lb import failed: auth (HTTP $http_code)"
        if [ -z "$(get_lb_api_key)" ]; then
          dim "  → cm set api-key <key>"
        else
          dim "  → API key invalid; cm set api-key <new-key>"
        fi
        ;;
      *)
        red "codex-lb import failed (HTTP $http_code)"
        ;;
    esac
  fi
}

cmd_add_internal() {
  local name="$1"
  local dir="$ACCOUNTS_DIR/$name"
  mkdir -p "$dir"

  if [ -n "${SSH_CONNECTION:-}" ]; then
    cmd_add_remote "$name"
  else
    cmd_use "$name" > /dev/null 2>&1 || true
    codex login
    local email=$(get_email "$dir")
    [ -n "$email" ] && green "Done: $name ($email)" || green "Done: $name"
  fi
}

cmd_doctor() {
  local has_issue=0
  local codex_lb_up=false
  local codex_lb_url
  codex_lb_url=$(get_config lb_url)

  echo ""
  dim "━━━ codex-multi doctor ━━━"
  echo ""

  # Check codex-lb
  if [ -z "$codex_lb_url" ]; then
    dim "codex-lb: not configured"
    dim "  → cm set lb <ip:port>"
  else
    local http_code
    http_code=$(lb_curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$codex_lb_url/api/accounts" 2>/dev/null) || http_code="000"
    case "$http_code" in
      200)
        codex_lb_up=true
        green "codex-lb: running"
        dim "  → $codex_lb_url"
        ;;
      401|403)
        red "codex-lb: auth failed (HTTP $http_code)"
        if [ -z "$(get_lb_api_key)" ]; then
          dim "  → cm set api-key <key>"
        else
          dim "  → API key invalid; cm set api-key <new-key>"
        fi
        has_issue=1
        ;;
      000)
        red "codex-lb: not running"
        dim "  → sudo docker start codex-lb"
        has_issue=1
        ;;
      *)
        red "codex-lb: unhealthy (HTTP $http_code)"
        dim "  → $codex_lb_url"
        has_issue=1
        ;;
    esac
  fi

  echo ""

  # Check each local account
  for dir in "$ACCOUNTS_DIR"/*/; do
    [ ! -d "$dir" ] && continue
    local name=$(basename "$dir")
    local email=$(get_email "$dir")
    local label="$name${email:+ ($email)}"

    if [ ! -f "$dir/auth.json" ]; then
      red "$label: no auth.json"
      dim "  → cm reauth $name"
      has_issue=1
      continue
    fi

    # Check if token is expired
    local expired=$(python3 -c "
import json, time
try:
  d = json.load(open('$dir/auth.json'))
  ts = d.get('tokens',{}).get('access_token','')
  # Decode JWT exp
  import base64
  payload = ts.split('.')[1]
  payload += '=' * (4 - len(payload) % 4)
  info = json.loads(base64.b64decode(payload))
  exp = info.get('exp', 0)
  if exp < time.time():
    print('expired')
  else:
    remaining = (exp - time.time()) / 86400
    print(f'{remaining:.0f}d')
except: print('unknown')
" 2>/dev/null)

    if [ "$expired" = "expired" ]; then
      dim "$label: access token expired (auto-refreshes on next use)"
    elif [ "$expired" = "unknown" ]; then
      dim "$label: token status unknown"
    else
      green "$label: OK (access token renews in ${expired})"
    fi
  done

  # Check codex-lb accounts if running
  if $codex_lb_up; then
    echo ""
    dim "━━━ codex-lb accounts ━━━"
    echo ""

    local lb_api_key
    lb_api_key=$(get_lb_api_key)
    python3 -c "
import urllib.request, json

req = urllib.request.Request('$codex_lb_url/api/accounts')
api_key = '$lb_api_key'
if api_key:
    req.add_header('Authorization', f'Bearer {api_key}')
resp = urllib.request.urlopen(req)
data = json.loads(resp.read())

for acc in data.get('accounts', []):
    email = acc['email']
    status = acc['status']
    usage = acc.get('usage', {})
    primary = usage.get('primaryRemainingPercent', 0)
    secondary = usage.get('secondaryRemainingPercent', 0)
    name = email.split('@')[0]

    if status == 'active':
        print(f'\033[32m{email}: active (quota: {primary:.0f}% primary, {secondary:.0f}% secondary)\033[0m')
    elif status == 'quota_exceeded':
        reset = acc.get('resetAtSecondary', 'unknown')
        print(f'\033[31m{email}: quota exceeded (reset: {reset})\033[0m')
        print(f'\033[90m  → Chờ quota reset hoặc thêm account mới: cm add <name>\033[0m')
    elif status == 'deactivated':
        reason = acc.get('deactivationReason', 'unknown')
        print(f'\033[31m{email}: deactivated ({reason})\033[0m')
        print(f'\033[90m  → sudo docker stop codex-lb && cm reauth {name} && sudo docker start codex-lb\033[0m')
    else:
        print(f'\033[31m{email}: {status}\033[0m')
        print(f'\033[90m  → Check codex-lb dashboard: $codex_lb_url\033[0m')
" 2>/dev/null

    local active=$(lb_curl -sf "$codex_lb_url/api/accounts" | python3 -c "import json,sys; d=json.load(sys.stdin); print(sum(1 for a in d['accounts'] if a['status']=='active'))" 2>/dev/null)
    local total=$(lb_curl -sf "$codex_lb_url/api/accounts" | python3 -c "import json,sys; d=json.load(sys.stdin); print(len(d['accounts']))" 2>/dev/null)

    echo ""
    if [ "$active" = "0" ]; then
      red "⚠ Không có account nào active! AI services sẽ không hoạt động."
      dim "  → Thêm account: sudo docker stop codex-lb && cm add <name> && sudo docker start codex-lb"
      has_issue=1
    else
      green "$active/$total accounts active"
    fi
  fi

  echo ""
  if [ $has_issue -eq 0 ]; then
    green "✓ All good"
  fi
}

cmd_balance_lb() {
  local codex_lb_url
  codex_lb_url=$(get_config lb_url)
  [ -z "$codex_lb_url" ] && return 1
  local lb_api_key
  lb_api_key=$(get_lb_api_key)
  python3 -c "
import urllib.request, json, os, base64

req = urllib.request.Request('$codex_lb_url/api/accounts')
api_key = '$lb_api_key'
if api_key:
    req.add_header('Authorization', f'Bearer {api_key}')
resp = urllib.request.urlopen(req, timeout=3)
data = json.loads(resp.read())
accounts_dir = '$ACCOUNTS_DIR'

best_name = None
best_remaining = -1

for acc in data.get('accounts', []):
    if acc['status'] != 'active':
        continue
    email = acc['email']
    secondary = acc.get('usage', {}).get('secondaryRemainingPercent', 0)

    for name in os.listdir(accounts_dir):
        auth_file = os.path.join(accounts_dir, name, 'auth.json')
        if not os.path.isfile(auth_file):
            continue
        try:
            d = json.load(open(auth_file))
            token = d.get('tokens', {}).get('id_token', '')
            if token:
                payload = token.split('.')[1]
                payload += '=' * (4 - len(payload) % 4)
                info = json.loads(base64.b64decode(payload))
                if info.get('email', '') == email:
                    label = f'{name} ({email})'
                    print(f'\033[90m  {label}: {secondary:.0f}% remaining\033[0m')
                    if secondary > best_remaining:
                        best_remaining = secondary
                        best_name = name
        except:
            pass

if best_name:
    with open('$1', 'w') as f:
        f.write(f'{best_name}|{best_remaining}')
" 2>/dev/null
}

cmd_balance() {
  local result_file=$(mktemp)
  local codex_lb_url
  codex_lb_url=$(get_config lb_url)

  # Try codex-lb first (fast, cached)
  if [ -n "$codex_lb_url" ] && lb_curl -sf "$codex_lb_url/api/accounts" > /dev/null 2>&1; then
    dim "via codex-lb"
    cmd_balance_lb "$result_file"
  fi

  # Fallback: query OpenAI directly
  if [ ! -s "$result_file" ]; then
    dim "via OpenAI API"
    python3 -c "
import json, os, base64, urllib.request, sys

accounts_dir = '$ACCOUNTS_DIR'
AUTH_URL = 'https://auth.openai.com/oauth/token'
USAGE_URL = 'https://chatgpt.com/backend-api/wham/usage'
CLIENT_ID = 'app_EMoamEEZ73f0CkXaXp7hrann'

best_name = None
best_remaining = -1

for name in sorted(os.listdir(accounts_dir)):
    auth_file = os.path.join(accounts_dir, name, 'auth.json')
    if not os.path.isfile(auth_file):
        continue

    try:
        d = json.load(open(auth_file))
        refresh_token = d.get('tokens', {}).get('refresh_token', '')
        if not refresh_token:
            print(f'\033[90m  {name}: no refresh token\033[0m')
            continue

        # Get account ID from id_token
        account_id = ''
        id_token = d.get('tokens', {}).get('id_token', '')
        claims = {}
        if id_token:
            payload = id_token.split('.')[1]
            payload += '=' * (4 - len(payload) % 4)
            claims = json.loads(base64.b64decode(payload))
            account_id = claims.get('https://api.openai.com/auth', {}).get('chatgpt_account_id', '')

        # Refresh access token
        req = urllib.request.Request(AUTH_URL, method='POST',
            data=json.dumps({
                'grant_type': 'refresh_token',
                'client_id': CLIENT_ID,
                'refresh_token': refresh_token,
                'scope': 'openid profile email'
            }).encode(),
            headers={'Content-Type': 'application/json'})
        resp = json.loads(urllib.request.urlopen(req, timeout=10).read())
        access_token = resp.get('access_token', '')

        if not access_token:
            print(f'\033[31m  {name}: token refresh failed\033[0m')
            continue

        # Query usage
        headers = {'Authorization': f'Bearer {access_token}', 'Accept': 'application/json'}
        if account_id and not account_id.startswith('email_') and not account_id.startswith('local_'):
            headers['chatgpt-account-id'] = account_id
        req = urllib.request.Request(USAGE_URL, headers=headers)
        usage = json.loads(urllib.request.urlopen(req, timeout=10).read())

        secondary = usage.get('rate_limit', {}).get('secondary_window', {})
        used = secondary.get('used_percent', 100)
        remaining = 100 - used

        email = claims.get('email', '')
        label = f'{name} ({email})' if email else name
        print(f'\033[90m  {label}: {remaining:.0f}% remaining\033[0m')

        if remaining > best_remaining:
            best_remaining = remaining
            best_name = name

    except Exception as e:
        print(f'\033[31m  {name}: {e}\033[0m')
        continue

if best_name:
    with open('$result_file', 'w') as f:
        f.write(f'{best_name}|{best_remaining}')
"
  fi

  local result=$(cat "$result_file" 2>/dev/null)
  rm -f "$result_file"

  if [ -z "$result" ] || [[ "$result" != *"|"* ]]; then
    red "No active account found"
    exit 1
  fi

  local name="${result%%|*}"
  local remaining="${result##*|}"
  local current=$(get_default)

  echo ""
  if [ "$name" = "$current" ]; then
    green "Already using best account: $name (${remaining}% remaining)"
  else
    cmd_use "$name"
    green "Switched to $name (${remaining}% remaining)"
  fi
}

cmd_run() {
  local name="$1"; shift
  [ ! -d "$ACCOUNTS_DIR/$name" ] && red "Account '$name' not found" && exit 1

  local prev_default=$(get_default)
  cmd_use "$name" > /dev/null
  local exit_code=0
  codex "$@" || exit_code=$?
  [ -n "$prev_default" ] && [ "$prev_default" != "$name" ] && cmd_use "$prev_default" > /dev/null
  return $exit_code
}

cmd_run_default() {
  local default=$(get_default)
  [ -z "$default" ] && red "No default account. Run: codex-multi add <name>" && exit 1
  codex "$@"
}

# --- Main ---

[ $# -eq 0 ] && cmd_ls && exit 0

case "$1" in
  add)
    [ $# -lt 2 ] && red "Usage: codex-multi add <name>" && exit 1
    cmd_add "$2" ;;
  rm|remove)
    [ $# -lt 2 ] && red "Usage: codex-multi rm <name>" && exit 1
    cmd_rm "$2" ;;
  ls|list)
    cmd_ls ;;
  use)
    [ $# -lt 2 ] && red "Usage: codex-multi use <name>" && exit 1
    cmd_use "$2" ;;
  set)
    [ $# -lt 3 ] && red "Usage: codex-multi set <lb|api-key> <value>" && exit 1
    cmd_set "$2" "$3" ;;
  get)
    [ $# -lt 2 ] && red "Usage: codex-multi get <lb|api-key>" && exit 1
    cmd_get "$2" ;;
  status)
    cmd_status "${2:-}" ;;
  doctor)
    cmd_doctor ;;
  balance|bal)
    cmd_balance ;;
  migrate)
    case "${2:-}" in
      --undo)  cmd_migrate_undo ;;
      --clean) rm -f "$MULTI_HOME"/pre-migrate-*.tar.gz && green "Migration backups removed" ;;
      "")      cmd_migrate ;;
      *)       red "Usage: codex-multi migrate [--undo|--clean]" && exit 1 ;;
    esac
    ;;
  backup)
    [ $# -lt 2 ] && red "Usage: codex-multi backup <file.tar.gz>" && exit 1
    cmd_backup "$2" ;;
  restore)
    [ $# -lt 2 ] && red "Usage: codex-multi restore <file.tar.gz>" && exit 1
    cmd_restore "$2" ;;
  reauth)
    [ $# -lt 2 ] && red "Usage: codex-multi reauth [--lb] <name>" && exit 1
    local _sync_lb=0
    shift
    while [ $# -gt 0 ]; do
      case "$1" in
        --lb) _sync_lb=1; shift ;;
        *) break ;;
      esac
    done
    [ $# -lt 1 ] && red "Usage: codex-multi reauth [--lb] <name>" && exit 1
    cmd_reauth "$1" "$_sync_lb" ;;
  import)
    [ $# -lt 3 ] && red "Usage: codex-multi import <name> <auth.json | ->" && exit 1
    cmd_import "$2" "$3" ;;
  export)
    [ $# -lt 2 ] && red "Usage: codex-multi export <name>" && exit 1
    cmd_export "$2" ;;
  help|-h|--help)
    cat << 'HELP'
codex-multi — manage multiple Codex CLI accounts

Commands:
  add <name>              Login and save a new account
  balance (bal)           Switch to account with most remaining quota
  backup <file.tar.gz>    Archive all accounts/config for transfer
  doctor                  Check health of all accounts + codex-lb
  get lb                  Show saved codex-lb URL
  get api-key             Show saved codex-lb API key
  restore <file.tar.gz>   Restore all accounts/config from archive
  reauth [--lb] <name>    Re-login existing account (--lb to also import to codex-lb)
  set lb <addr>           Save codex-lb URL (supports ip:port, http://, https://)
  set api-key <key>       Save codex-lb API key (sent as Authorization: Bearer <key>)
  migrate                 Merge history/sessions from all accounts into shared ~/.codex
  migrate --undo          Restore pre-migration backup
  migrate --clean         Remove migration backup
  import <name> <file|->  Import auth.json from file or stdin
  export <name>           Print auth.json to stdout
  rm <name>               Remove an account
  ls                      List all accounts (* = default)
  use <name>              Set default account
  status [name]           Check login status
  <name> [args...]        Run codex with specific account
  [args...]               Run codex with default account

Headless setup (SSH/remote):
  1. On PC:   CODEX_HOME=/tmp/myaccount codex login
  2. Copy:    scp /tmp/myaccount/auth.json user@pi:~/
  3. On Pi:   codex-multi import myaccount ~/auth.json

Examples:
  codex-multi add personal
  codex-multi backup /tmp/codex-multi.tar.gz
  codex-multi set lb 192.168.1.88:2455
  codex-multi set api-key sk-clb-...
  codex-multi restore /tmp/codex-multi.tar.gz
  codex-multi import work /tmp/auth.json
  codex-multi use personal
  codex-multi work exec "list files"
  codex-multi exec "list files"
HELP
    ;;
  *)
    if [ -d "$ACCOUNTS_DIR/$1" ]; then
      cmd_run "$@"
    else
      cmd_run_default "$@"
    fi
    ;;
esac
